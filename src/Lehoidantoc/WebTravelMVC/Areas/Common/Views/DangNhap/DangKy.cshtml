@model NguyenDuyQuang.Models.TaiKhoan
@{
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link href="https://fonts.googleapis.com/css?family=Poppins:300,400,600,700,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/Assets/Login/css/bootstrap.min.css">
    <link rel="shortcut icon" type="image/x-icon" href="~/Assets/KhachHang/img/logo/VT2.png">

    <title>Đăng Ký Tài Khoản - Lễ Hội Khmer</title>

    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background-color: #0f172a;
        }

        /* Lớp nền ảnh */
        .login-bg {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: url('/Assets/images/AnhDuLich.jpg');
            background-size: cover;
            background-position: center;
            z-index: 1;
        }

        /* Lớp phủ tối */
        .bg-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15, 23, 42, 0.7);
            z-index: 2;
        }

        /* Form Glassmorphism */
        .glass-login-box {
            position: relative;
            z-index: 3;
            width: 100%;
            max-width: 500px;
            margin: 20px auto;
            background: rgba(30, 41, 59, 0.6);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
            color: #f8fafc;
        }

        .glass-login-box h3 {
            color: #fbbf24;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            text-align: center;
        }

        label {
            font-weight: 500;
            color: #e2e8f0;
            margin-bottom: 5px;
            font-size: 0.9rem;
        }

        .form-control {
            background: rgba(15, 23, 42, 0.5) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: #f8fafc !important;
            border-radius: 10px;
            padding: 10px 15px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            border-color: #fbbf24 !important;
            box-shadow: 0 0 0 0.2rem rgba(251, 191, 36, 0.25) !important;
        }

        .btn-primary {
            background-color: #fbbf24 !important;
            border: none !important;
            color: #0f172a !important;
            font-weight: 700;
            text-transform: uppercase;
            padding: 12px;
            border-radius: 10px;
            width: 100%;
            margin-top: 15px;
            transition: 0.3s;
        }

        .btn-primary:hover {
            background-color: #f59e0b !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(251, 191, 36, 0.4);
        }

        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: #cbd5e1;
            text-decoration: none;
            font-size: 0.9rem;
        }

        .back-link:hover {
            color: #fbbf24;
        }

        .error-msg {
            color: #f87171;
            background: rgba(248, 113, 113, 0.1);
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 15px;
            font-size: 0.85rem;
            border: 1px solid rgba(248, 113, 113, 0.2);
        }
    </style>
</head>
<body>

    <div class="login-bg"></div>
    <div class="bg-overlay"></div>

    <div class="container d-flex align-items-center justify-content-center min-vh-100">
        <div class="glass-login-box">
            <h3>Đăng Ký Tài Khoản</h3>

            @using (Html.BeginForm("DangKy", "DangNhap", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                if (ViewBag.error != null)
                {
                    <div class="error-msg">
                        <i class="icon-warning mr-2"></i> @ViewBag.error
                    </div>
                }

                <div class="row">
                    <div class="col-md-12 form-group mb-3">
                        <label>Tên đăng nhập (Email/Mã TK)</label>
                        @Html.TextBoxFor(m => m.MaTaiKhoan, new { @class = "form-control", placeholder = "Nhập tên tài khoản...", required = "required" })
                    </div>

                    <div class="col-md-12 form-group mb-3">
                        <label>Mật khẩu</label>
                        @Html.PasswordFor(m => m.MatKhau, new { @class = "form-control", placeholder = "Nhập mật khẩu...", required = "required" })
                    </div>

                    <div class="col-md-12 form-group mb-3">
                        <label>Họ và Tên</label>
                        @Html.TextBoxFor(m => m.HoTen, new { @class = "form-control", placeholder = "Nguyễn Văn A", required = "required" })
                    </div>

                    <div class="col-md-12 form-group mb-3">
                        <label>Số điện thoại</label>
                        @Html.TextBoxFor(m => m.SDT, new { @class = "form-control", placeholder = "0123456789", required = "required" })
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">Đăng Ký Ngay</button>

                <a href="@Url.Action("DangNhap", "DangNhap")" class="back-link">
                    <i class="icon-arrow-left"></i> Đã có tài khoản? Đăng nhập
                </a>
            }
        </div>
    </div>

    <script src="~/Assets/Login/js/jquery-3.3.1.min.js"></script>
    <script src="~/Assets/Login/js/bootstrap.min.js"></script>
</body>
</html>